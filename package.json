{
  "name": "claude-says",
  "version": "1.0.2",
  "description": "Real-time text-to-speech companion for Claude Code CLI — hear Claude think and narrate as it works",
  "type": "module",
  "bin": {
    "claude-says": "bin/claude-says.js",
    "claude-says-hook": "bin/claude-says-hook.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/claude-says.js",
    "setup": "node bin/claude-says.js setup",
    "postinstall": "echo '\n  claude-says installed! Run: claude-says setup\n'"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tts",
    "text-to-speech",
    "accessibility",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhishek141001/claude-code-speak"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "optionalDependencies": {
    "@google-cloud/text-to-speech": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
